{
  "name": "next-pwa-professional",
  "version": "1.0.0",
  "description": "Professional PWA package for Next.js with App Router, offline support, and beautiful UI",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build",
    "postinstall": "node scripts/setup.js"
  },
  "keywords": ["nextjs", "pwa", "offline", "typescript", "app-router"],
  "peerDependencies": {
    "next": ">=14.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "@ducanh2912/next-pwa": "^10.0.0",
    "idb": "^8.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "files": [
    "dist",
    "scripts",
    "templates",
    "README.md"
  ]
}